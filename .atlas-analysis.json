{
  "projectType": "sdk-library",
  "projectName": "Sandcastle",
  "projectDescription": "A TypeScript library and CLI for orchestrating AI coding agents in isolated sandboxes, managing sandbox lifecycle, branch strategies, prompts, and iterations.",
  "theme": "luma",
  "primaryColor": "#040404",
  "lightColor": "#354dc4",
  "darkColor": "#94a4e4",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "concepts"
            ]
          },
          {
