  },
  "keyFeatures": [
    "Provider-agnostic sandbox orchestration (Docker, Podman, Vercel, custom)",
    "Flexible branch strategies: head, merge-to-head, and named branch",
    "Dynamic prompt system with argument substitution and shell expression expansion",
    "Structured output extraction with schema validation (Zod/Valibot)",
    "Lifecycle hooks for host and sandbox setup steps",
    "Session capture and resume for Claude Code agents",
    "Parallel agent orchestration via multiple sandcastle.run() calls",
    "Init scaffold with ready-to-use templates for common workflows",
    "AbortSignal support for cancellation"
  ],
  "publicApiSurface": [
    "run(options: RunOptions): Promise<RunResult>",
    "createSandbox(options: CreateSandboxOptions): Promise<Sandbox>",
    "createWorktree(options: CreateWorktreeOptions): Promise<Worktree>",
    "interactive(options: InteractiveOptions): Promise<InteractiveResult>",
    "claudeCode(model, options?): AgentProvider",
    "codex(model, options?): AgentProvider",
    "opencode(model, options?): AgentProvider",
    "pi(model, options?): AgentProvider",
    "Output.object({ tag, schema }): OutputDefinition",
    "Output.string({ tag }): OutputDefinition",
    "createBindMountSandboxProvider(...): SandboxProvider",
    "createIsolatedSandboxProvider(...): SandboxProvider",
    "docker(options?): BindMountSandboxProvider",
    "podman(options?): BindMountSandboxProvider",
    "vercel(options?): IsolatedSandboxProvider",
    "noSandbox(): NoSandboxProvider",
    "sandcastle init",
    "sandcastle docker build-image",
    "sandcastle docker remove-image",
    "sandcastle podman build-image",
    "sandcastle podman remove-image"
  ]
}
